# Application
PORT=3000
NODE_ENV=development

# Base de données PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sigp_db?schema=public"

# JWT — Générer des secrets forts en production
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_in_production_too
JWT_REFRESH_EXPIRES_IN=7d

# Upload de fichiers
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=10

# CORS — séparer plusieurs origines par des virgules
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Bcrypt
BCRYPT_SALT_ROUNDS=12
